# =============================================================================
# VARIABLES DE ENTORNO - SISTEMA COTIZACIÓN DE TRANSPORTE B2B
# =============================================================================
# 
# IMPORTANTE: Este archivo es un template de ejemplo (.env.example)
# Copia este archivo como .env y completa los valores reales
# NO commitear el archivo .env con valores reales en Git
#
# Comando: cp .env.example .env (Linux/Mac) o copy .env.example .env (Windows)
# =============================================================================

# -----------------------------------------------------------------------------
# BASE DE DATOS POSTGRESQL
# -----------------------------------------------------------------------------
# URL de conexión a PostgreSQL
# Formato: postgresql://[usuario]:[password]@[host]:[puerto]/[nombre_db]
#
# Opciones:
# 1. PostgreSQL Local:
#    DATABASE_URL=postgresql://postgres:password@localhost:5432/cotizaciones_db
#
# 2. Supabase (recomendado para desarrollo):
#    DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
#
# 3. Railway, Render, u otro hosting:
#    DATABASE_URL=[URL_PROPORCIONADA_POR_SERVICIO]
#
DATABASE_URL=postgresql://user:password@localhost:5432/cargoclick_web_db

# -----------------------------------------------------------------------------
# SERVICIO DE EMAIL (RESEND)
# -----------------------------------------------------------------------------
# API Key de Resend para envío de emails
# Obtener en: https://resend.com/api-keys
#
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email remitente (debe estar verificado en Resend)
# Para desarrollo: onboarding@resend.dev (provisto por Resend)
# Para producción: tu dominio verificado (ej: notificaciones@tuempresa.com)
#
EMAIL_FROM=onboarding@resend.dev

# Email del administrador (recibe notificaciones de solicitudes)
# Aquí llegarán los correos cuando un cliente complete una solicitud
#
EMAIL_ADMIN=admin@tuempresa.com

# -----------------------------------------------------------------------------
# SERVICIO WHATSAPP (ULTRAMSG)
# -----------------------------------------------------------------------------
# API Key de Ultramsg para envío de mensajes WhatsApp
# Obtener en: https://ultramsg.com/dashboard
#
ULTRAMSG_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Instance ID de Ultramsg (identificador de tu instancia WhatsApp)
# Formato: instance12345
#
ULTRAMSG_INSTANCE_ID=instance12345

# Número de WhatsApp del administrador (incluir código país sin +)
# Formato: [código_país][número]
# Ejemplos:
#   Colombia: 573001234567
#   México: 525512345678
#   España: 34612345678
#
WHATSAPP_ADMIN_NUMBER=573001234567

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE APLICACIÓN
# -----------------------------------------------------------------------------
# Entorno de ejecución
# Valores: development | production | test
#
NODE_ENV=development

# URL pública de la aplicación
# Usada para generar links en emails y notificaciones
#
# Desarrollo local: http://localhost:3000
# Producción: https://tudominio.com
#
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# AUTENTICACIÓN (CLERK)
# -----------------------------------------------------------------------------
# Obtener en: https://dashboard.clerk.com → tu aplicación → API Keys
#
# IMPORTANTE: Las claves pk_test_/sk_test_ solo funcionan en localhost.
# Para producción debes crear una app separada en Clerk y usar pk_live_/sk_live_
#
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL de la página de sign-in (debe coincidir con el path en app/sign-in)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# URL a donde redirigir después de hacer login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/solicitudes

# =============================================================================
# RNDC — MINISTERIO DE TRANSPORTE (Módulo Operacional)
# =============================================================================
#
# Modo de operación del cliente SOAP RNDC.
# "test"       → Llama al servidor de PRUEBAS del Ministerio (plc.mintransporte.gov.co) — DEFAULT
# "produccion" → Llama al servidor de PRODUCCIÓN. Solo en Railway/Vercel/prod.
#
RNDC_MODO=test

# URL servidor de PRUEBAS
RNDC_WS_URL_TEST=http://plc.mintransporte.gov.co:8080/ws/maestros?wsdl

# URL servidor de PRODUCCIÓN primario y contingencia
RNDC_WS_URL=http://rndcws.mintransporte.gov.co:8080/ws/maestros?wsdl
RNDC_WS_URL_CONTINGENCIA=http://rndcws2.mintransporte.gov.co:8080/ws/maestros?wsdl

# NIT de la empresa (compartido entre test y produccion)
RNDC_NIT_EMPRESA=900000000

# Credenciales TEST (servidor plc.mintransporte.gov.co)
RNDC_USUARIO_TEST=usuario_pruebas
RNDC_CLAVE_TEST=clave_pruebas

# Credenciales PRODUCCIÓN (servidor rndcws.mintransporte.gov.co)
RNDC_USUARIO=usuario_produccion
RNDC_CLAVE=clave_produccion

# =============================================================================
# NOTAS DE SEGURIDAD
# =============================================================================
#
# ⚠️  NUNCA commitear el archivo .env con valores reales
# ⚠️  Agregar .env al .gitignore (ya incluido)
# ⚠️  Rotar API keys si son expuestas accidentalmente
# ⚠️  Usar variables de entorno en plataformas de hosting (Vercel, Railway, etc.)
#
# =============================================================================

# =============================================================================
# PENDIENTE: RATE LIMITER DISTRIBUIDO (UPSTASH REDIS)
# =============================================================================
# El rate limiter actual usa memoria en proceso (in-memory).
# En despliegues con múltiples workers esto NO funciona correctamente.
#
# Para habilitar rate limiting distribuido:
# 1. Crear cuenta en https://upstash.com
# 2. Crear base de datos Redis
# 3. Descomentar y completar las variables de abajo
# 4. Instalar dependencias: npm install @upstash/ratelimit @upstash/redis
# 5. Actualizar lib/utils/ratelimit.ts para usar @upstash/ratelimit
#
# Ver ítem PENDIENTE-B en TECH_DEBT.md
#
# UPSTASH_REDIS_REST_URL=https://xxxxxxxxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# =============================================================================
